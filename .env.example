# ===== 必填 =====
# 你的 AI API Key（从 DeepSeek / OpenAI / Gemini 获取）
UPSTREAM_API_KEY=sk-your-api-key

# 审计 Token（用于访问 Query API，建议使用强密码）
ERC_API_TOKEN=your-secure-token-here

# 允许的上游域名（逗号分隔，用于安全验证）
ALLOWED_UPSTREAM_HOSTS=api.deepseek.com

# ===== 可选（已有默认值）=====
# 上游 API 地址（默认 DeepSeek，可改为 OpenAI / Gemini / 本地模型）
UPSTREAM_URL=https://api.deepseek.com/anthropic/v1/messages

# CORS 允许的来源（前端地址，默认 localhost:3000）
ERC_CORS_ORIGIN=http://localhost:3000

# Gateway 监听地址（默认 0.0.0.0:8080）
GATEWAY_LISTEN=0.0.0.0:8080